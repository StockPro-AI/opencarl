{
  "name": "opencarl",
  "version": "2.1.19",
  "description": "OpenCARL - Dynamic rule injection for OpenCode. Rules load when relevant, disappear when not. Adapted from CARL by Chris Kahler.",
  "main": "dist/plugin.js",
  "types": "dist/plugin.d.ts",
  "bin": {
    "opencarl": "bin/install.js"
  },
  "files": [
    "bin",
    "dist",
    "resources",
    ".opencarl-template"
  ],
  "scripts": {
    "build": "npx tsc --project tsconfig.build.json && node -e \"const fs=require('fs'); const p='dist/plugin.js'; if(!fs.existsSync(p)){console.error('ERROR: '+p+' not found');process.exit(1)} console.log('[build] OpenCARL plugin built successfully'); console.log('[build] Output: '+require('path').resolve(p))\"",
    "prepublishOnly": "npm run build && node scripts/verify-dist.js",
    "release": "npm run build && npm publish --access public",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --testPathIgnorePatterns='tests/javascript/e2e'",
    "test:unit": "jest --testPathPattern='tests/javascript/unit'",
    "test:integration": "jest --testPathPattern='tests/javascript/integration'",
    "test:e2e": "jest --testPathPattern='tests/javascript/e2e'",
    "test:e2e:local": "bash tests/e2e/run-e2e-tests.sh",
    "test:e2e:ci": "bash tests/e2e/run-e2e-tests.sh",
    "docs": "typedoc",
    "docs:ci": "typedoc --gitRevision $(git rev-parse HEAD)"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "opencarl",
    "opencode-opencarl",
    "rules",
    "context",
    "dynamic-rules",
    "prompt-engineering"
  ],
  "author": "Kristian Gray",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrisGray/opencarl.git"
  },
  "bugs": {
    "url": "https://github.com/KrisGray/opencarl/issues"
  },
  "homepage": "https://github.com/KrisGray/opencarl#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.2.0"
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.2.15",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  }
}
