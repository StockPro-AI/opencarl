#!/bin/bash
# Mock OpenCode CLI for E2E testing of CARL plugin
# This simulates OpenCode CLI behavior without requiring the actual CLI

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Working directory
WORKSPACE_DIR="/workspace"

# Parse command
if [ "$1" = "setup" ]; then
    # Simulate *carl setup command
    echo -e "${GREEN}🚀 Initializing CARL plugin...${NC}"
    echo "Creating .carl/ directory structure..."
    echo "Loading default configuration..."

    # Check if .carl exists, if so it's idempotent
    if [ -f "${WORKSPACE_DIR}/.carl/manifest" ]; then
        echo -e "${YELLOW}CARL already initialized. Using existing configuration.${NC}"
        echo ""
        cat "${WORKSPACE_DIR}/.carl/manifest"
        echo ""
        echo "✓ Setup complete (idempotent)"
        exit 0
    fi

    # Create .carl directory structure
    mkdir -p "${WORKSPACE_DIR}/.carl/global"
    mkdir -p "${WORKSPACE_DIR}/.carl/domains"
    mkdir -p "${WORKSPACE_DIR}/.carl/state"
    mkdir -p "${WORKSPACE_DIR}/.carl/prompts"

    # Create default manifest
    cat > "${WORKSPACE_DIR}/.carl/manifest" << 'EOF'
# CARL Plugin Manifest
# Generated by OpenCode E2E tests

DEVMODE=true

# Global domain (always loaded)
[GLOBAL]
STATE=active
ALWAYS_ON=true

# Context domain (always loaded)
[CONTEXT]
STATE=active
ALWAYS_ON=true

# Commands domain (always loaded)
[COMMANDS]
STATE=active
RECALL=paritytest

# Development domain (toggle test domain)
[DEVELOPMENT]
STATE=inactive
EOF

    echo -e "${GREEN}✓ .carl/ directory created${NC}"
    echo -e "${GREEN}✓ Default manifest written${NC}"
    echo -e "${GREEN}✓ Configuration loaded${NC}"
    echo ""
    cat "${WORKSPACE_DIR}/.carl/manifest"
    echo ""
    echo "✓ Setup complete"

elif [ "$1" = "status" ]; then
    # Simulate *carl status command
    echo -e "${GREEN}📊 CARL Plugin Status${NC}"
    echo ""
    echo "Active Domains:"
    echo "  • GLOBAL (always on)"
    echo "  • CONTEXT (always on)"
    echo "  • COMMANDS (always on)"
    echo ""
    echo "Inactive Domains:"
    echo "  • DEVELOPMENT (toggle test domain)"
    echo ""
    echo "Configuration: .carl/manifest"

elif [ "$1" = "list" ]; then
    # Simulate *carl list command
    echo -e "${GREEN}📋 Available Commands${NC}"
    echo ""
    echo "Setup Commands:"
    echo "  *carl setup        - Initialize CARL plugin"
    echo ""
    echo "Status Commands:"
    echo "  *carl status       - Show domain status"
    echo "  *carl list         - List available commands"
    echo ""
    echo "Toggle Commands:"
    echo "  *carl toggle       - Toggle domain activation"

elif [ "$1" = "toggle" ]; then
    # Simulate *carl toggle command
    echo -e "${GREEN}🔄 Toggle Domain${NC}"
    echo ""
    echo "Available domains to toggle:"
    echo "  • DEVELOPMENT (currently inactive)"
    echo ""
    echo "To toggle: *carl toggle <domain>"

elif [[ "$1" == "toggle"* ]]; then
    # Simulate *carl toggle <domain> command
    DOMAIN="${1#toggle }"

    if [ -z "$DOMAIN" ]; then
        echo "Error: No domain specified"
        echo "Usage: *carl toggle <domain>"
        exit 1
    fi

    echo -e "${GREEN}🔄 Toggling ${DOMAIN}...${NC}"

    # Read current state
    if [ -f "${WORKSPACE_DIR}/.carl/manifest" ]; then
        CURRENT_STATE=$(grep "^\[$DOMAIN\]" -A 1 "${WORKSPACE_DIR}/.carl/manifest" | grep "STATE=" | cut -d'=' -f2)

        if [ "$CURRENT_STATE" = "active" ]; then
            NEW_STATE="inactive"
            echo -e "${YELLOW}Deactivating ${DOMAIN}${NC}"
        else
            NEW_STATE="active"
            echo -e "${GREEN}Activating ${DOMAIN}${NC}"
        fi

        # Update manifest (simple sed for testing)
        if [ "$(uname)" = "Darwin" ]; then
            sed -i '' "/^\[$DOMAIN\]/,/^\[/{s/STATE=.*/STATE=$NEW_STATE/;}" "${WORKSPACE_DIR}/.carl/manifest"
        else
            sed -i "/^\[$DOMAIN\]/,/^\[/{s/STATE=.*/STATE=$NEW_STATE/;}" "${WORKSPACE_DIR}/.carl/manifest"
        fi

        echo "✓ ${DOMAIN} is now ${NEW_STATE}"
    else
        echo "Error: .carl/manifest not found. Run *carl setup first."
        exit 1
    fi

else
    echo "Error: Unknown command '$1'"
    echo ""
    echo "Usage: *carl <command>"
    echo ""
    echo "Available commands:"
    echo "  setup   - Initialize CARL plugin"
    echo "  status  - Show domain status"
    echo "  list    - List available commands"
    echo "  toggle  - Toggle domain activation"
    exit 1
fi
