#!/bin/bash
# Mock OpenCode CLI for E2E testing of OpenCARL plugin
# This simulates OpenCode CLI behavior without requiring the actual CLI

set -e

# Colors for output
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Working directory
WORKSPACE_DIR="/workspace"
OPENCARL_DIR="${WORKSPACE_DIR}/.opencarl"
MANIFEST_PATH="${OPENCARL_DIR}/manifest"

write_default_manifest() {
    cat > "$MANIFEST_PATH" << 'EOF'
# OpenCARL Manifest
# ===============
# Controls which domains are active and how they're triggered.
#
# Format:
#   DEVMODE=<true|false>              (debug output in responses)
#   {DOMAIN}_STATE=active|inactive    (whether domain is enabled)
#   {DOMAIN}_ALWAYS_ON=true|false     (load every prompt, no keyword matching)
#   {DOMAIN}_RECALL=keyword1,keyword2 (triggers on-demand loading)
#   {DOMAIN}_EXCLUDE=word1,word2      (skip domain if these words in prompt)

# ============================================================================
# SETTINGS
# ============================================================================
DEVMODE=true

# ============================================================================
# GLOBAL - Universal rules (always loaded)
# ============================================================================
GLOBAL_STATE=active
GLOBAL_ALWAYS_ON=true

# ============================================================================
# CONTEXT - Dynamic bracket rules based on context window usage
# ============================================================================
CONTEXT_STATE=active
CONTEXT_ALWAYS_ON=true

# ============================================================================
# COMMANDS - Star-commands like *dev, *review, *brief
# Detected via *pattern matching, rules in commands file
# ============================================================================
COMMANDS_STATE=active
COMMANDS_RECALL=paritytest

# ============================================================================
# DEVELOPMENT - Toggle test domain
# ============================================================================
DEVELOPMENT_STATE=inactive
DEVELOPMENT_RECALL=fix bug,debug,test code
DEVELOPMENT_ALWAYS_ON=false
EOF
}

ensure_opencarl_structure() {
    mkdir -p "$OPENCARL_DIR"
    mkdir -p "${OPENCARL_DIR}/sessions"
    touch "${OPENCARL_DIR}/global"
    touch "${OPENCARL_DIR}/commands"
    touch "${OPENCARL_DIR}/context"
}

set_domain_state() {
    local domain="$1"
    local state="$2"

    if ! grep -q "^${domain}_STATE=" "$MANIFEST_PATH"; then
        echo "Error: Unknown domain '$domain'"
        exit 1
    fi

    sed -i "s/^${domain}_STATE=.*/${domain}_STATE=${state}/" "$MANIFEST_PATH"
}

# Parse command
if [ "$1" = "setup" ]; then
    echo -e "${GREEN}🚀 Initializing OpenCARL plugin...${NC}"
    echo "Creating .opencarl/ directory structure..."
    echo "Loading default configuration..."

    if [ -f "$MANIFEST_PATH" ]; then
        echo -e "${YELLOW}OpenCARL already initialized. Using existing configuration.${NC}"
        echo ""
        cat "$MANIFEST_PATH"
        echo ""
    echo "setup complete (idempotent)"
        exit 0
    fi

    ensure_opencarl_structure
    write_default_manifest

    echo -e "${GREEN}✓ .opencarl/ directory created${NC}"
    echo -e "${GREEN}✓ Default manifest written${NC}"
    echo -e "${GREEN}✓ Configuration loaded${NC}"
    echo ""
    cat "$MANIFEST_PATH"
    echo ""
    echo "setup complete"

elif [ "$1" = "status" ]; then
    echo -e "${GREEN}📊 OpenCARL Plugin Status${NC}"
    echo ""
    echo "Active Domains:"
    echo "  • GLOBAL (always on)"
    echo "  • CONTEXT (always on)"
    echo "  • COMMANDS (keyword triggered)"
    echo ""
    echo "Configuration: .opencarl/manifest"

elif [ "$1" = "list" ]; then
    echo -e "${GREEN}📋 Available Commands${NC}"
    echo ""
    echo "Setup Commands:"
    echo "  *opencarl setup        - Initialize OpenCARL plugin"
    echo ""
    echo "Status Commands:"
    echo "  *opencarl status       - Show domain status"
    echo "  *opencarl list         - List available commands"
    echo ""
    echo "Toggle Commands:"
    echo "  *opencarl toggle <DOMAIN> <active|inactive>"

elif [ "$1" = "toggle" ]; then
    DOMAIN="$2"
    NEW_STATE="$3"

    if [ -z "$DOMAIN" ] || [ -z "$NEW_STATE" ]; then
        echo "Error: Missing domain or state"
        echo "Usage: *opencarl toggle <DOMAIN> <active|inactive>"
        exit 1
    fi

    if [ ! -f "$MANIFEST_PATH" ]; then
        echo "Error: .opencarl/manifest not found. Run *opencarl setup first."
        exit 1
    fi

    if [ "$NEW_STATE" != "active" ] && [ "$NEW_STATE" != "inactive" ]; then
        echo "Error: Invalid state '$NEW_STATE'"
        exit 1
    fi

    set_domain_state "$DOMAIN" "$NEW_STATE"
    echo "✓ ${DOMAIN} is now ${NEW_STATE}"

else
    echo "Error: Unknown command '$1'"
    echo ""
    echo "Usage: *opencarl <command>"
    echo ""
    echo "Available commands:"
    echo "  setup   - Initialize OpenCARL plugin"
    echo "  status  - Show domain status"
    echo "  list    - List available commands"
    echo "  toggle  - Toggle domain activation"
    exit 1
fi
